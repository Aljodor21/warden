#!/usr/bin/env bash
#
# warden — gestor de backups/restauración consciente de discos.
#
#   Detecta CUALQUIER disco (interno o externo), identifica los discos de
#   backup warden (por marcador + repo restic con tags) y permite respaldar
#   o restaurar los componentes que elijas. El disco es la "opción": conectás
#   uno y el tool decide si se restaura desde él o se inicializa como destino.
#
# Subcomandos:
#   menu                (por defecto) Menú principal
#   status              Muestra discos, config y catálogo
#   doctor              Chequeo de salud del sistema
#   install             Lanza el instalador (bootstrap.sh)
#   backup              [root] Respalda todo el catálogo (restic)
#   install-component <tag> [root] Instala UN componente del catálogo (ej. filebrowser)
#   verify              [root] restic check (integridad del repo)
#   register            [root] Fija el disco en fstab + activa los timers
#   cloudflare-init      [root] Crea un túnel de Cloudflare desde cero (una vez)
#   publish             [root] (Re)genera el ingress de Cloudflare desde el catálogo
#   runner <url> <tok>  [root] Registra un self-hosted runner de GitHub Actions
#   secrets <accion>    [root] Cifra/restaura secretos con age (init|save|restore)
#   vpn                 [root] Instala y conecta Tailscale (VPN)
#   homepage            [root] Regenera la config de Homepage y la recarga
#   panel               [root] Instala el panel web del catálogo (:7890)
#   nas <accion> ...    [root] Usuarios del NAS (adduser|passwd|deluser|users)
#   reset               [root] Instalación limpia TOTAL: borra todo lo que warden tocó
#   init-disk <dev>     [root] Prepara un disco NUEVO como destino de backup
#   restore             Restaura un backup (restore/restore.sh)
#   list-disks          Lista discos físicos
#   catalog             Lista los componentes del catálogo
#
set -uo pipefail

# Resolver el symlink (ej. /usr/local/bin/warden) para hallar la raíz real del repo.
_self="$(readlink -f "${BASH_SOURCE[0]}")"
HERE="$(cd "$(dirname "$_self")/.." && pwd)"
WARDEN_ROOT="$HERE"; export WARDEN_ROOT
# Config del sitio (WARDEN_LAN, WARDEN_HOSTNAME, etc.) — bootstrap.sh la carga
# sola, pero si corrés 'warden <algo>' directo (sin pasar por bootstrap) en la
# misma sesión, también tiene que estar disponible acá.
[ -f "$HERE/site/site.conf" ] && source "$HERE/site/site.conf"
# shellcheck source=/dev/null
source "$HERE/lib/distro.sh"
# shellcheck source=/dev/null
source "$HERE/lib/catalog.sh"
# shellcheck source=/dev/null
source "$HERE/lib/core.sh"
# shellcheck source=/dev/null
source "$HERE/lib/ui.sh"
# shellcheck source=/dev/null
source "$HERE/modules/stacks.sh"
# shellcheck source=/dev/null
source "$HERE/modules/backup.sh"
# shellcheck source=/dev/null
source "$HERE/modules/register.sh"
# shellcheck source=/dev/null
source "$HERE/modules/doctor.sh"
# shellcheck source=/dev/null
source "$HERE/modules/cloudflare.sh"
# shellcheck source=/dev/null
source "$HERE/modules/cloudflare_init.sh"
# shellcheck source=/dev/null
source "$HERE/modules/runner.sh"
# shellcheck source=/dev/null
source "$HERE/modules/secrets.sh"
# shellcheck source=/dev/null
source "$HERE/modules/motd.sh"
# shellcheck source=/dev/null
source "$HERE/modules/tailscale.sh"
# shellcheck source=/dev/null
source "$HERE/modules/homepage.sh"
# shellcheck source=/dev/null
source "$HERE/modules/panel.sh"
# shellcheck source=/dev/null
source "$HERE/modules/nas.sh"
# shellcheck source=/dev/null
source "$HERE/modules/reset.sh"
# shellcheck source=/dev/null
source "$HERE/modules/initdisk.sh"

CONFIG_DIR="/etc/warden"
CONFIG_FILE="$CONFIG_DIR/config"
MARKER=".warden-backup.id"     # marca que identifica un disco de backup warden

# --- colores (solo si es terminal) -------------------------------------------
if [ -t 1 ]; then
  C_RESET=$'\e[0m'; C_DIM=$'\e[2m'; C_B=$'\e[1m'
  C_GREEN=$'\e[32m'; C_YEL=$'\e[33m'; C_BLUE=$'\e[34m'
else
  C_RESET=""; C_DIM=""; C_B=""; C_GREEN=""; C_YEL=""; C_BLUE=""
fi

# --- helpers de disco --------------------------------------------------------

# UUID del disco fijo registrado (si existe config)
registered_uuid() {
  [ -r "$CONFIG_FILE" ] || return 0
  awk -F= '/^BACKUP_UUID=/{print $2}' "$CONFIG_FILE" 2>/dev/null
}

# Si alguna partición montada del disco tiene el marcador, imprime su mountpoint
disk_marker_mount() {
  local disk="$1" name mp
  while read -r name mp; do
    [ -n "${mp:-}" ] || continue
    if [ -f "$mp/$MARKER" ]; then echo "$mp"; return 0; fi
  done < <(lsblk -rpno NAME,MOUNTPOINT "$disk" 2>/dev/null)
  return 1
}

# ¿El disco tiene algún sistema de archivos? (=> tiene datos)
disk_has_fs() {
  lsblk -rpno FSTYPE "$1" 2>/dev/null | grep -qE '\S'
}

# Clasifica un disco -> imprime "ROL|detalle"
classify_disk() {
  local disk="$1" sysd reg mp id
  sysd="$(system_disk)"
  reg="$(registered_uuid)"
  if [ "${disk##*/}" = "$sysd" ]; then
    echo "SYSTEM|disco del sistema (/)"; return
  fi
  if mp="$(disk_marker_mount "$disk")"; then
    id="$(cat "$mp/$MARKER" 2>/dev/null)"
    echo "BACKUP|backup warden · montado en $mp · id=${id:-?}"; return
  fi
  if [ -n "$reg" ] && lsblk -rpno UUID "$disk" 2>/dev/null | grep -qx "$reg"; then
    echo "BACKUP|backup warden (registrado, sin montar)"; return
  fi
  if disk_has_fs "$disk"; then
    echo "OTHER|tiene datos (no es backup warden)"
  else
    echo "EMPTY|vacío / sin formato"
  fi
}

icon_for() {
  case "$1" in
    SYSTEM) printf '%s' "${C_BLUE}■${C_RESET}" ;;
    BACKUP) printf '%s' "${C_GREEN}✔${C_RESET}" ;;
    OTHER)  printf '%s' "${C_YEL}?${C_RESET}" ;;
    EMPTY)  printf '%s' "${C_DIM}o${C_RESET}" ;;
  esac
}

# --- subcomandos -------------------------------------------------------------

cmd_status() {
  echo "${C_B}== warden ==${C_RESET}"
  echo
  echo "${C_B}Discos detectados:${C_RESET}"
  printf "  %-7s %-8s %-5s %-20s %s\n" "DISCO" "TAM" "BUS" "MODELO" "ROL"
  local name size type tran model role cls
  while read -r name size type tran model; do
    [ "$type" = "disk" ] || continue
    cls="$(classify_disk "$name")"; role="${cls%%|*}"
    printf "  %-7s %-8s %-5s %-20s %s %s\n" \
      "${name##*/}" "$size" "${tran:-?}" "${model:-?}" "$(icon_for "$role")" "${cls#*|}"
  done < <(lsblk -dpno NAME,SIZE,TYPE,TRAN,MODEL)
  echo

  local reg; reg="$(registered_uuid)"
  if [ -n "$reg" ]; then
    echo "${C_B}Disco fijo (backup automático):${C_RESET} UUID=$reg"
  else
    echo "${C_B}Disco fijo (backup automático):${C_RESET} ${C_DIM}ninguno registrado aún${C_RESET}"
  fi
  echo

  echo "${C_B}Catálogo (qué se puede instalar / respaldar):${C_RESET}"
  printf "  %-18s %-10s %s\n" "TAG" "TIPO" "DESCRIPCIÓN"
  local tag nm kind src
  while IFS='|' read -r tag nm kind src; do
    printf "  %-18s %-10s %s\n" "$tag" "$kind" "$nm"
  done < <(catalog_each)
  echo
  echo "${C_DIM}Más:  warden install · warden restore${C_RESET}"
}

cmd_menu() {
  local opt
  opt="$(ui_menu 'warden — ¿qué querés hacer?' \
    'Estado del sistema' 'Chequeo de salud' 'Hacer un backup' 'Restaurar un backup' \
    'Activar backup automático' 'Instalar / configurar' 'Salir')"
  case "$opt" in
    'Estado del sistema')        cmd_status ;;
    'Chequeo de salud')          warden_doctor ;;
    'Hacer un backup')           exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/bin/warden" backup ;;
    'Restaurar un backup')       exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/restore/restore.sh" ;;
    'Activar backup automático') exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/bin/warden" register ;;
    'Instalar / configurar')     exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/bootstrap.sh" ;;
    *) : ;;
  esac
}

case "${1:-menu}" in
  menu)        cmd_menu ;;
  status)      cmd_status ;;
  doctor)      warden_doctor ;;
  install)     exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/bootstrap.sh" ;;
  backup)      need_root; warden_backup ;;
  install-component) need_root; warden_stack_install "${2:-}" ;;
  verify)      need_root; warden_verify ;;
  register)    need_root; warden_register ;;
  cloudflare-init) need_root; warden_cloudflare_init ;;
  publish)     need_root; warden_publish ;;
  runner)      need_root; warden_runner "${2:-}" "${3:-}" ;;
  vpn)         need_root; warden_tailscale_install ;;
  homepage)    need_root; warden_homepage_config; docker restart homepage >/dev/null 2>&1 || true; ok "Homepage regenerado y recargado" ;;
  panel)       need_root; warden_panel_install ;;
  nas)
    need_root
    case "${2:-}" in
      adduser) warden_nas_adduser "${3:-}" "${4:-}" ;;
      passwd)  warden_nas_passwd "${3:-}" "${4:-}" ;;
      deluser) warden_nas_deluser "${3:-}" ;;
      reload)  warden_nas_reload ;;
      users|"") warden_nas_users "${3:-}" ;;
      *) echo "Uso: warden nas {adduser|passwd|deluser|reload|users} [nombre] [clave]"; exit 1 ;;
    esac
    ;;
  motd)        need_root; warden_motd_install ;;
  reset)       need_root; warden_reset ;;
  init-disk)   need_root; warden_init_disk "${2:-}" ;;
  secrets)
    need_root
    case "${2:-}" in
      init)    warden_secrets_init ;;
      save)    warden_secrets_save ;;
      restore) warden_secrets_restore ;;
      *) echo "Uso: warden secrets {init|save|restore}"; exit 1 ;;
    esac
    ;;
  restore)     exec sudo --preserve-env=WARDEN_RESTORE_AUTO,WARDEN_DRY_RUN,WARDEN_BACKUP_MOUNT,RESTIC_PASS_FILE,WARDEN_RESTORE_DIR,WARDEN_DATA bash "$HERE/restore/restore.sh" "${@:2}" ;;
  list-disks)  lsblk -dpno NAME,SIZE,TYPE,TRAN,MODEL | awk '$3=="disk"' ;;
  catalog)     catalog_each ;;
  -h|--help|help) sed -n '2,30p' "$0" | sed 's/^#\s\{0,1\}//' ;;
  *) echo "Subcomando desconocido: $1 (probá: menu, status, install, restore)"; exit 1 ;;
esac
